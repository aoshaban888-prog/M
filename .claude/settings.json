{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "shell": "bash",
            "command": "git add -A && git diff --cached --quiet || (git commit -m \"auto: website update\" && git push origin master)",
            "statusMessage": "رفع التحديثات إلى GitHub...",
            "timeout": 30
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(git *)"
    ]
  }
}
